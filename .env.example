DATABASE_URL="file:./dev.db"

# Demo auth keeps the MVP self-contained. Replace this with real auth before production.
DEMO_USER_EMAIL="founder@hirewave.local"

# AI provider for the candidate coaching assistant.
#   deterministic      -> local rule-based responses (default; used in tests)
#   ollama             -> Yelo-hosted Ollama-compatible endpoint
#   openai-compatible  -> any OpenAI-compatible endpoint (NVIDIA Build, OpenAI, ...)
#                         (alias: nvidia)
AI_PROVIDER="deterministic"

# --- openai-compatible / NVIDIA Build provider ---
# Get a free key + model id at https://build.nvidia.com
# AI_API_KEY also falls back to NVIDIA_API_KEY / OPENAI_API_KEY.
AI_API_KEY=""
AI_BASE_URL="https://integrate.api.nvidia.com/v1"
AI_MODEL="deepseek-ai/deepseek-v4-flash"
# Reasoning controls (deepseek-style). Keep effort low for the coaching surface.
AI_REASONING_EFFORT="low"
AI_THINKING="true"
AI_TEMPERATURE="1"
AI_TOP_P="0.95"
AI_MAX_TOKENS="4096"
AI_MAX_RETRIES="1"

# Legacy OpenAI vars are still read as fallbacks for AI_API_KEY / AI_BASE_URL.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- ollama provider ---
OLLAMA_BASE_URL="http://yeloai.yelo.solutions"
OLLAMA_MODEL="minimax-m2.5:cloud"

# Shared request timeout (ms) for hosted AI providers.
AI_TIMEOUT_MS="30000"

# --- Agent mode (aiMode='agent') ---
# Tool-calling needs a capable model (NOT an 8B). Coaching keeps AI_MODEL above.
# Best tool-calling + speed: Groq llama-3.3-70b-versatile (api.groq.com/openai/v1).
AGENT_MODEL="meta/llama-3.3-70b-instruct"
AGENT_MAX_TOKENS="4096"
AGENT_REASONING_EFFORT="low"

# Sandbox provider is simulated for MVP. Production should use E2B, Daytona, CodeSandbox, or a microVM-backed provider.
SANDBOX_PROVIDER="simulated"
# Local-dev execution is for trusted local development only. It is not production isolation.
SANDBOX_LOCAL_DEV_ENABLED="false"
SANDBOX_LOCAL_ALLOWED_COMMANDS="npm test"
SANDBOX_LOCAL_DEV_KEEP_WORKSPACE="false"
SANDBOX_COMMAND_TIMEOUT_MS="10000"
SANDBOX_COMMAND_OUTPUT_LIMIT="20000"
SANDBOX_SNAPSHOT_FILE_LIMIT="200"
SANDBOX_SNAPSHOT_CONTENT_LIMIT="100000"
# Optional placeholder for SANDBOX_PROVIDER=external until a concrete adapter is implemented.
SANDBOX_EXTERNAL_PROVIDER_ID=""

# --- DSA judge (code execution) ---
#   judge0 -> Judge0 engine. Fastest start: public CE (no key/card, rate-limited):
#             JUDGE0_URL=https://ce.judge0.com
#             Production/volume: self-host -> http://localhost:2358 (docker-compose.judge0.yml)
#   local  -> deterministic in-process runner (tests/dev only, not real isolation)
JUDGE_PROVIDER="judge0"
JUDGE0_URL="https://ce.judge0.com"
JUDGE0_TOKEN=""
