  "title": "Phone Numbers",
  "track": "real-world",
  "topic": "patterns",
  "difficulty": "easy",
  "statementMd": "A phone number is a string of length 11 matching the pattern `8xxxxxxxxxx` (a leading `8` followed by ten digits).\n\nYou have a set of digit cards given as the string `digits` (each character is one card). Using each card in at most one phone number, return the maximum number of phone numbers you can form. You do not have to use every card, and the phone numbers need not be distinct.",
  "constraintsMd": "- `1 <= digits.length <= 100`\n- Each character of `digits` is a decimal digit `0`-`9`.",
  "inputFormat": null,
  "outputFormat": null,
  "comparison": "whitespace",
  "floatEpsilon": null,
  "timeLimitMs": 2000,
  "memoryLimitMb": 256,
  "attribution": "Adapted to function form from the DeepMind code_contests dataset (CC BY 4.0). Original problem: Codeforces.",
  "categoryTags": [
    "greedy",
    "strings"
  ],
  "companyTags": [],
  "hints": [
    "A phone number needs exactly 11 cards and must start with the digit 8.",
    "So each phone number costs one 8 plus ten other cards.",
    "The answer is limited by both the count of 8s and how many groups of 11 cards you have."
  ],
  "kind": "function",
  "functionName": "maxPhoneNumbers",
